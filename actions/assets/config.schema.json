{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Archive Configuration Schema",
  "type": "object",
  "properties": {
    "archives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "folder": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["folder", "name"],
        "additionalProperties": false
      }
    }
  },
  "required": ["archives"],
  "additionalProperties": false
}